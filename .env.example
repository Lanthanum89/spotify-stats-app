# This app is now a pure static site — there's no server process left to read
# a .env file. This file is just a reference for the one value you need.
#
# Copy this value into the `spotify-client-id` <meta> tag in public/index.html.
# The Client ID is not a secret (it's visible in every request Spotify makes
# from the browser anyway) — only the Client Secret was sensitive, and this
# app no longer uses a Client Secret at all.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Optional: port for the local static-file dev server (server.js / npm start).
PORT=3000
